---
import MainLayout from '../layouts/MainLayout.astro';
import { 
	legal,
	general, 
	contracts 
} from '../data/lists';
---


<MainLayout>
	<div class="p-2 overflow-auto flex flex-col">
		<div class="flex gap-2 items-center">
			<p class="">DOCS</p>
			<a 
				href="https://19188103.com" 
				class="underline">19-18-8-103
			</a>
		</div>

		{/* LEGAL */}
		<span class="mt-4 mb-1 text-document">
			⎯⎯ legal ⎯⎯
		</span>
		{legal.map((item) => (
			<a 
				href={item.path}
				class="hover:underline text-document pl-2"
			>
			• {item.title}
			</a>
		))}

		{/* GENERAL */}
		<span class="mt-4 mb-1 text-computer">
			⎯⎯ general ⎯⎯
		</span>
		{general.map((item) => (
			<a 
				href={item.path}
				class="hover:underline text-computer pl-2"
			>
			• {item.title}
			</a>
		))}

		{/* CONTRACTS */}
		<span class="mt-4 mb-1 text-contract">
			⎯⎯ contracts ⎯⎯
		</span>
		{contracts.map((item) => (
			<a 
				href={item.path}
				class="hover:underline text-contract pl-2"
			>
			• {item.title}
			</a>
		))}
	</div>
</MainLayout>
