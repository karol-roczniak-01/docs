{
	"compatibility_date": "2025-09-27",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "docs",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"routes": [
		{
			"pattern": "docs.robotagroup.com",
			"zone_name": "robotagroup.com",
			"custom_domain": true
		}
	],
	"observability": {
		"enabled": true
	}
}